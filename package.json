{
  "name": "localreader",
  "version": "1.0.0",
  "description": "A local-first EPUB and PDF reader for macOS.",
  "main": "electron/main.cjs",
  "scripts": {
    "dev:web": "vite",
    "dev": "NODE_ENV=development electron .",
    "build": "vite build",
    "preview": "vite preview",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder --mac"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "@vitejs/plugin-react": "^6.0.1",
    "adm-zip": "^0.5.17",
    "epubjs": "^0.3.93",
    "pdfjs-dist": "^5.6.205",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "vite": "^8.0.8"
  },
  "devDependencies": {
    "electron": "^41.2.1",
    "electron-builder": "^26.0.12",
    "icon-gen": "^5.0.0"
  },
  "build": {
    "appId": "com.link.localreader",
    "productName": "Local Reader",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "mac": {
      "identity": null,
      "icon": "build/app.icns",
      "category": "public.app-category.productivity",
      "target": [
        "dmg",
        "zip"
      ]
    }
  }
}
